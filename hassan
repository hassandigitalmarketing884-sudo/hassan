<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Hassan Digital Marketing - Professional Digital Marketing Services in Multan, Pakistan. Logo Design, Branding, Social Media Marketing & More.">
    <meta name="keywords" content="digital marketing, logo design, branding, multan, pakistan, hassan digital marketing">
    <meta name="author" content="Hassan Digital Marketing">
    <title>Hassan Digital Marketing | Professional Digital Marketing Agency in Multan, Pakistan</title>
    
    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚀</text></svg>">
    
    <!-- Google Fonts & Custom Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        @font-face {
            font-family: 'Hunters';
            src: url('data:font/otf;base64,...') format('opentype');
            font-weight: normal;
            font-style: normal;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --ink-black: #00111c;
            --ink-black-2: #001523;
            --prussian-blue: #001a2c;
            --prussian-blue-2: #002137;
            --deep-space-blue: #00253e;
            --deep-space-blue-2: #002945;
            --deep-space-blue-3: #002e4e;
            --deep-space-blue-4: #003356;
            --yale-blue: #003a61;
            --yale-blue-2: #00406c;
            --accent: #ff6b35;
            --accent-glow: #ff8c5a;
            --white: #ffffff;
            --text-light: #b8c1d4;
        }

        html {
            scroll-behavior: smooth;
            scroll-padding-top: 80px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--ink-black);
            color: var(--white);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(0, 17, 28, 0.95);
            backdrop-filter: blur(20px);
            z-index: 1000;
            padding: 1rem 0;
            transition: all 0.3s ease;
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Hunters', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--accent), var(--yale-blue-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-link {
            color: var(--text-light);
            text-decoration: none;
            font-weight: 500;
            position: relative;
            transition: all 0.3s ease;
            padding: 0.5rem 0;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent), var(--accent-glow));
            transition: width 0.3s ease;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .nav-link:hover {
            color: var(--white);
        }

        .cta-btn {
            padding: 12px 30px;
            background: linear-gradient(135deg, var(--accent), var(--accent-glow));
            color: var(--white);
            border: none;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.3);
        }

        .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(135deg, var(--ink-black) 0%, var(--deep-space-blue) 50%, var(--yale-blue) 100%);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000"><defs><radialGradient id="a" cx="50%" cy="50%"><stop offset="0%" stop-color="%23ff6b3508"/><stop offset="100%" stop-color="transparent"/></radialGradient></defs><circle fill="url(%23a)" cx="200" cy="200" r="100"/><circle fill="url(%23a)" cx="800" cy="300" r="80"/><circle fill="url(%23a)" cx="400" cy="700" r="120"/></svg>');
            animation: float 20s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(180deg); }
        }

        .hero-content h1 {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, var(--white) 0%, var(--accent) 50%, var(--yale-blue-2) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { filter: drop-shadow(0 0 20px var(--accent)); }
            to { filter: drop-shadow(0 0 30px var(--accent-glow)); }
        }

        .hero-content p {
            font-size: 1.5rem;
            max-width: 600px;
            margin: 0 auto 3rem;
            color: var(--text-light);
        }

        /* Dragon Button */
        .dragon-btn {
            position: relative;
            padding: 20px 50px;
            font-size: 1.3rem;
            color: var(--white);
            background: linear-gradient(45deg, var(--accent), var(--accent-glow));
            border: none;
            border-radius: 50px;
            cursor: pointer;
            overflow: hidden;
            z-index: 2;
            font-weight: 600;
            box-shadow: 0 20px 40px rgba(255, 107, 53, 0.3);
            transition: all 0.3s ease;
        }

        .dragon-btn:hover {
            transform: translateY(-3px);
        }

        .dragon {
            position: absolute;
            width: 150px;
            height: 150px;
            border: 3px solid var(--accent-glow);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(0deg);
            opacity: 0;
            pointer-events: none;
            animation: spin 1.5s linear infinite;
        }

        .dragon-btn:hover .dragon {
            opacity: 1;
        }

        @keyframes spin {
            from { transform: translate(-50%, -50%) rotate(0deg); }
            to { transform: translate(-50%, -50%) rotate(360deg); }
        }

        /* Sections */
        .section {
            padding: 120px 0;
            max-width: 1400px;
            margin: 0 auto;
            padding-left: 2rem;
            padding-right: 2rem;
        }

        .section-title {
            font-size: 3.5rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 4rem;
            background: linear-gradient(135deg, var(--white), var(--yale-blue-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Services */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            margin-top: 4rem;
        }

        .service-card {
            background: rgba(0, 37, 78, 0.3);
            padding: 2.5rem;
            border-radius: 20px;
            border: 1px solid rgba(255, 107, 53, 0.2);
            backdrop-filter: blur(10px);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 107, 53, 0.1), transparent);
            transition: left 0.5s;
        }

        .service-card:hover::before {
            left: 100%;
        }

        .service-card:hover {
            transform: translateY(-10px);
            background: rgba(0, 37, 78, 0.5);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
        }

        .service-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--accent), var(--accent-glow));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1.5rem;
        }

        /* Pricing */
        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 4rem;
        }

        .pricing-card {
            background: rgba(0, 37, 78, 0.3);
            padding: 3rem 2rem;
            border-radius: 25px;
            border: 2px solid transparent;
            backdrop-filter: blur(15px);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            text-align: center;
        }

        .pricing-card.featured {
            border-color: var(--accent);
            transform: scale(1.05);
        }

        .pricing-card:hover {
            border-color: var(--accent);
            transform: translateY(-15px);
        }

        .price {
            font-size: 4rem;
            font-weight: 800;
            color: var(--accent);
            margin: 1rem 0;
        }

        .price span {
            font-size: 1.5rem;
            color: var(--text-light);
        }

        /* Contact */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            margin-top: 4rem;
        }

        .contact-info h3 {
            font-size: 1.8rem;
            margin-bottom: 2rem;
            color: var(--accent);
        }

        .contact-item {
            display: flex;
            align-items: center;
            margin-bottom: 1.5rem;
            padding: 1rem;
            background: rgba(255, 107, 53, 0.1);
            border-radius: 15px;
            transition: all 0.3s ease;
        }

        .contact-item:hover {
            background: rgba(255, 107, 53, 0.2);
            transform: translateX(10px);
        }

        .contact-form {
            background: rgba(0, 37, 78, 0.3);
            padding: 3rem;
            border-radius: 25px;
            backdrop-filter: blur(15px);
        }

        .form-group {
            margin-bottom: 2rem;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 1rem 1.5rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 107, 53, 0.3);
            border-radius: 15px;
            color: var(--white);
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 20px rgba(255, 107, 53, 0.3);
        }

        /* Chatbot */
        .chatbot-toggle {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--accent), var(--accent-glow));
            border: none;
            border-radius: 50%;
            color: var(--white);
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(255, 107, 53, 0.4);
            z-index: 1001;
            transition: all 0.3s ease;
        }

        .chatbot-toggle:hover {
            transform: scale(1.1);
        }

        .chatbot {
            position: fixed;
            bottom: 110px;
            right: 30px;
            width: 350px;
            height: 500px;
            background: rgba(0, 37, 78, 0.95);
            border-radius: 20px;
            backdrop-filter: blur(20px);
            transform: scale(0);
            transform-origin: bottom right;
            transition: all 0.3s ease;
            z-index: 1001;
            display: flex;
            flex-direction: column;
        }

        .chatbot.active {
            transform: scale(1);
        }

        .chatbot-header {
            padding: 1.5rem;
            background: linear-gradient(135deg, var(--accent), var(--accent-glow));
            border-radius: 20px 20px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chatbot-messages {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        .chatbot-input {
            padding: 1.5rem;
            border-top: 1px solid rgba(255, 107, 53, 0.2);
        }

        .message {
            margin-bottom: 1rem;
            padding: 1rem;
            border-radius: 15px;
        }

        .message.bot {
            background: rgba(255, 107, 53, 0.2);
        }

        .message.user {
            background: rgba(255, 255, 255, 0.1);
            margin-left: 20%;
        }

        /* Footer */
        .footer {
            background: var(--prussian-blue);
            padding: 4rem 0 2rem;
            text-align: center;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-menu {
                display: none;
            }
            
            .contact-grid {
                grid-template-columns: 1fr;
            }
            
            .section-title {
                font-size: 2.5rem;
            }
            
            .chatbot {
                width: 90vw;
                right: 5vw;
            }
        }

        /* Scroll animations */
        .fade-in {
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.8s ease;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
